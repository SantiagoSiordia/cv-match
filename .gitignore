# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local uploads & generated data (never commit CVs/JDs/evaluations)
/cvs-pdf/*
!/cvs-pdf/.gitkeep
/cvs-extracted/*
!/cvs-extracted/.gitkeep
/cvs-meta/*
!/cvs-meta/.gitkeep
/cvs/*
!/cvs/.gitkeep
/job-descriptions/*
!/job-descriptions/.gitkeep
/evaluations/*
!/evaluations/.gitkeep
/embeddings/*
!/embeddings/.gitkeep

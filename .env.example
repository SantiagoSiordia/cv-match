# Optional: persistent data directory (Docker/EFS). Defaults to cwd.
# CV_MATCH_DATA_ROOT=/data

# Optional: parallel GitHub CV downloads during full seed (default 2; max 8). LLM calls still per file.
# SEED_CV_CONCURRENCY=2

# AI routing: auto (default) = try Amazon Bedrock first, then Google Gemini if Bedrock fails or AWS region is unset.
# Force one provider: bedrock | gemini
# AI_PROVIDER=auto

# Google Gemini (fallback in auto mode, or set AI_PROVIDER=gemini for local dev without AWS keys)
# GEMINI_API_KEY=
# Retries with backoff for 503/429 etc. (default 5)
# GEMINI_MAX_RETRIES=5
# Cheapest defaults: gemini-2.5-flash-lite (text), text-embedding-004 (embeddings)
# GEMINI_TEXT_MODEL=gemini-2.5-flash-lite
# GEMINI_EMBEDDING_MODEL=text-embedding-004

# Amazon Bedrock (preferred when AWS_REGION is set and credentials work; IAM role on AWS or local AWS credentials)
# AWS_REGION=us-east-1
# BEDROCK_TEXT_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
# BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
